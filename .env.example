# ===================================================================
# Vendor Cost Portal — environment variable template
# Copy to `.env` (git-ignored) for local use, or set these as
# Application Settings in Azure App Service for production.
# ===================================================================

# ── Core ──────────────────────────────────────────────────────────
PORT=3000
# Absolute path to the SQLite file. On Azure App Service Linux, use
# a path under /home (which is persistent across restarts), e.g.
# /home/data/portal.db
DB_PATH=data/portal.db

# ── Auth (shared) ─────────────────────────────────────────────────
# REQUIRED in prod — generate with: openssl rand -hex 64
JWT_SECRET=dev-secret-change-in-prod
JWT_EXPIRY=8h
BCRYPT_ROUNDS=10

# ── Microsoft (Entra ID) auth — optional ─────────────────────────
# Leave all three empty to disable MS sign-in (password login still works).
# When all three are set, a "Sign in with Microsoft" button appears on
# the login screen and /api/auth/microsoft/* becomes active.
#
# - AZURE_CLIENT_ID / AZURE_CLIENT_SECRET: from your Entra app registration.
# - AZURE_AUTHORITY: multi-tenant work/school = /organizations,
#   single-tenant = /<your-tenant-id>, any MS account = /common.
# - OAUTH_REDIRECT_URI: must match the Redirect URI registered in Entra.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUTHORITY=https://login.microsoftonline.com/organizations
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# ── Email digest (daily fabric-request roundup) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
PD_EMAIL=
COMPANY_NAME=Costing Team
EMAIL_TIMEZONE=Asia/Hong_Kong
