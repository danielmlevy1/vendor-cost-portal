# macOS
.DS_Store
.AppleDouble
.LSOverride

# Node (if ever added)
node_modules/
npm-debug.log*

# Editor
.vscode/
.idea/

# Build artifacts
dist/

# Environment — never commit secrets. .env.example is safe to commit.
.env
.env.local
.env.*.local

# Database (generated at runtime — do not commit)
data/

# Docs — always commit, even if a future ignore rule would catch them
!docs/
!docs/**
